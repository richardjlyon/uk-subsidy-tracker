# Python
__pycache__/
*.pyc
*.egg-info/
dist/
build/
.venv/

# Raw datasets ≤100 MB are committed to git (per CLAUDE.md reproducibility policy).
# Larger files push to Cloudflare R2 with manifest pointer — add specific paths here.

# IDE
.idea/
.vscode/
*.swp
.env

# OS
.DS_Store

# Plot output
output/*.html
output/*.png
output/*.json

# Generated chart files (served by MkDocs)
docs/charts/html/*.html
docs/charts/html/*.png

# MkDocs build output. Phase 4 note: `site/data/` is produced by
# `uk_subsidy_tracker.refresh_all` and committed intentionally (D-15) —
# the daily refresh PR writes site/data/latest/cfd/* and site/data/manifest.json
# and Cloudflare Pages serves these from main. Git does not support
# re-including files under an ignored directory, so we ignore the mkdocs-build
# subtrees explicitly rather than blanket-ignoring site/.
/site/assets/
/site/stylesheets/
/site/search/
/site/sitemap.xml
/site/sitemap.xml.gz
/site/themes/
/site/methodology/
/site/charts/
/site/about/
/site/index.html
/site/404.html

# Claude workflow state
.claude/

# Confidential project management — outreach logs, strategic judgements,
# off-record notes. Distinct from .planning/ (GSD workspace, tracked).
# Everything inside .private/ stays out of the public repo.
.private/

# Phase 4: derived Parquet tables are regenerated from data/raw/ on every
# refresh. Only raw data + workflows + source + tests live in git.
data/derived/
